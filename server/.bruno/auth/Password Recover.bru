meta {
  name: Password Recover
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/password/recover
  body: json
  auth: none
}

body:json {
  {
    "email": "alice@acme.test"
  }
}

docs {
  Triggers a password-reset email. Token is logged via the
  ``EmailBackend = console`` setting in dev — copy from the server
  stdout into the ``resetPasswordToken`` env var.
}
