meta {
  name: Email Verify Request
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/auth/email/verify/request
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

docs {
  Requires a signed-in user (sends to ``request.user.email``). Token
  surfaces via the email backend; copy into ``emailVerifyToken``.
}
