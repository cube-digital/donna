SECRET_KEY=replace-me-in-production
DEBUG=True
TESTING=false
ALLOWED_HOSTS=*
LOG_LEVEL=INFO
LOG_FORMAT=console
UVICORN_RELOAD=true

DATABASE_NAME=donna
DATABASE_USERNAME=donna
DATABASE_PASSWORD=donna
DATABASE_HOST=database
DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=25
