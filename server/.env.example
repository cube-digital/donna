# Copy to .env for local docker-compose runs.

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-in-production
DEBUG=True
ALLOWED_HOSTS=*
LOG_LEVEL=INFO
LOG_FORMAT=console

# ─── Database ─────────────────────────────────────────────────────────────────
# compose sets this for web/worker; override for non-compose runs.
DATABASE_URL=postgres://donna:donna@postgres:5432/donna

# ─── Celery / Redis ───────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_ALWAYS_EAGER=False

# ─── Storage ──────────────────────────────────────────────────────────────────
# filesystem | s3 | gcs | azure
DONNA_STORAGE_BACKEND=filesystem
DONNA_FILESYSTEM_ROOT=/app/var/storage

# S3 (uncomment when DONNA_STORAGE_BACKEND=s3)
# DONNA_S3_BUCKET=donna-dev
# DONNA_S3_ENDPOINT_URL=  # leave empty for real AWS, set for MinIO/SeaweedFS/R2
# DONNA_S3_ACCESS_KEY=
# DONNA_S3_SECRET_KEY=
# DONNA_S3_REGION=us-east-1
# DONNA_S3_ADDRESSING_STYLE=virtual  # set to "path" for MinIO

# ─── Integrations ─────────────────────────────────────────────────────────────
# Comma-separated slugs to opt out of (left empty = all installed connectors loaded).
DONNA_DISABLED_INTEGRATIONS=

