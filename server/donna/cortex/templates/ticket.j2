---
type: ticket
title: {{ title }}
{% if occurred_at %}occurred_at: {{ occurred_at }}{% endif %}
parent_path: {{ data.parent_path }}
slug: {{ data.slug }}
template_version: ticket@v1
provider: {{ data.provider }}
external_id: "{{ data.external_id }}"
status: "{{ data.status }}"
{% if data.assignees %}assignees: [{% for a in data.assignees %}"{{ a }}"{% if not loop.last %}, {% endif %}{% endfor %}]{% endif %}
{% if data.parent_epic_id %}parent_epic_id: "{{ data.parent_epic_id }}"{% endif %}
{% if data.cluster_name %}cluster_name: "{{ data.cluster_name }}"{% endif %}
---

# {{ title }}

{{ body }}

Source: {{ source_uri }} ({{ bronze_storage_key }})
